# =============================================================================
#  .gitattributes
# =============================================================================
#  Normalize line endings across platforms so Windows checkouts (CRLF) and
#  Linux/macOS checkouts (LF) don't create spurious diffs.
# =============================================================================

# Default: text files use LF in the repo, CRLF on Windows checkout
* text=auto eol=lf

# Explicit LF (Unix-style) for source files
*.cpp   text eol=lf
*.h     text eol=lf
*.hpp   text eol=lf
*.c     text eol=lf
*.qml   text eol=lf
*.js    text eol=lf
*.ts    text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.qrc   text eol=lf
*.ui    text eol=lf
*.pro   text eol=lf
*.pri   text eol=lf
*.cmake text eol=lf
*.txt   text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.xml   text eol=lf
*.svg   text eol=lf
*.desktop text eol=lf

# Windows-only files keep CRLF
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Binary files — never touch them
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.icns  binary
*.pdf   binary
*.zip   binary
*.ttf   binary
*.otf   binary
*.woff  binary
*.woff2 binary
*.exe   binary
*.dll   binary
*.so    binary
*.dylib binary
*.a     binary
*.lib   binary
*.o     binary
*.obj   binary

# Linguist detection hints (for GitHub language stats)
*.qml   linguist-language=QML
*.qrc   linguist-language=XML
CMakeLists.txt linguist-language=CMake
*.cmake linguist-language=CMake

# Mark generated files so they don't pollute diffs / blame
build/** linguist-generated=true
*_metatype.json linguist-generated=true
